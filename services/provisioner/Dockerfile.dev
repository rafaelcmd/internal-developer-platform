ARG GO_VERSION=1.25

FROM golang:${GO_VERSION}

RUN useradd -m -u 1000 consumeruser
USER consumeruser

WORKDIR /usr/src/app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN go build -o /usr/src/app/bin/resource-provisioner-consumer ./cmd/consumer/main.go

CMD ["/usr/src/app/bin/resource-provisioner-consumer"]